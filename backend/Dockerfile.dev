FROM node:22

WORKDIR /app

# Install dependencies first for better caching
COPY package.json package-lock.json* ./
RUN npm install

# We need nodemon installed globally or available in node_modules
# It is already in package.json devDependencies, so npm install will install it.
# Copy everything else
COPY . .

# Execute nodemon
CMD ["npx", "nodemon", "./server.js"]
